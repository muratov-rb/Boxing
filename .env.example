# ============================================================================
# PRESSURE — environment variables
# Copy this file to `.env.local` and fill in the values. See SETUP.md for a
# full step-by-step. The app runs without these (auth + AI degrade gracefully).
# ============================================================================

# --- Supabase (auth + database) ---
# Project Settings → API → Project URL and the "anon / public" (or publishable) key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-KEY

# Show the "Continue with Google" button. Set to "true" ONLY after you enable the
# Google provider in Supabase (needs a Google Cloud OAuth client). Empty = hidden.
NEXT_PUBLIC_GOOGLE_ENABLED=

# --- Anthropic Claude (AI analysis + roadmap) ---
# https://console.anthropic.com → API keys. Server-only, never exposed.
ANTHROPIC_API_KEY=sk-ant-YOUR-KEY

# Optional: override the model (defaults to a current Claude model in code).
# ANTHROPIC_MODEL=claude-sonnet-5
